import { expect } from "chai";
import { createConduit } from "../../src/client/create-conduit.js";
import { rabbitMqTransport } from "../../src/transports/rabbitmq/index.js";

const RABBITMQ_URL = process.env.RABBITMQ_URL ?? "amqp://localhost";

function waitFor(assertion, { timeout = 3000, interval = 25 } = {}) {
  return new Promise((resolve, reject) => {
    const startedAt = Date.now();

    const check = () => {
      try {
        assertion();
        resolve();
      } catch (error) {
        if (Date.now() - startedAt >= timeout) {
          reject(error);
          return;
        }

        setTimeout(check, interval);
      }
    };

    check();
  });
}

describe("Client integration", function () {
  this.timeout(10000);

  let serviceA;
  let serviceB;

  beforeEach(async function () {
    const namespace = `conduit-test-${Date.now()}-${Math.random()
      .toString(16)
      .slice(2)}`;

    serviceA = createConduit({
      namespace,
      service: "service-a",
      transport: rabbitMqTransport({
        url: RABBITMQ_URL,
      }),
    });

    serviceB = createConduit({
      namespace,
      service: "service-b",
      transport: rabbitMqTransport({
        url: RABBITMQ_URL,
      }),
    });

    await serviceA.start();
    await serviceB.start();
  });

  afterEach(async function () {
    await Promise.allSettled([serviceA?.stop(), serviceB?.stop()]);
  });

  it("allows two services to receive events emitted by each other", async function () {
    const messagesReceivedByA = [];
    const messagesReceivedByB = [];

    await serviceA.on("service-b.message-sent", async function (message) {
      messagesReceivedByA.push(message);
    });

    await serviceB.on("service-a.message-sent", async function (message) {
      messagesReceivedByB.push(message);
    });

    await serviceA.emit("service-a.message-sent", {
      text: "Hello from service A",
    });

    await serviceB.emit("service-b.message-sent", {
      text: "Hello from service B",
    });

    await waitFor(() => {
      expect(messagesReceivedByA).to.have.lengthOf(1);
      expect(messagesReceivedByB).to.have.lengthOf(1);
    });

    expect(messagesReceivedByA[0]).to.deep.include({
      data: {
        text: "Hello from service B",
      },
    });

    expect(messagesReceivedByB[0]).to.deep.include({
      data: {
        text: "Hello from service A",
      },
    });

    expect(messagesReceivedByA[0].meta).to.include({
      kind: "event",
      type: "service-b.message-sent",
      source: "service-b",
    });

    expect(messagesReceivedByB[0].meta).to.include({
      kind: "event",
      type: "service-a.message-sent",
      source: "service-a",
    });

    expect(messagesReceivedByA[0].meta.id).to.be.a("string");
    expect(messagesReceivedByA[0].meta.timestamp).to.be.a("string");

    expect(messagesReceivedByB[0].meta.id).to.be.a("string");
    expect(messagesReceivedByB[0].meta.timestamp).to.be.a("string");
  });
});
